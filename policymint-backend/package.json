{
  "name": "policymint-backend",
  "version": "0.1.0",
  "description": "PolicyMint — Policy-Protected Autonomous Trading Agent Backend",
  "author": "Obaid Safi <obaid@policymint.xyz>",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config ./vitest.config.ts",
    "test:watch": "vitest --config ./vitest.config.ts",
    "test:unit": "vitest run --config ./vitest.config.ts src",
    "test:integration": "dotenv -e .env.test env RUN_DB_TESTS=true vitest run --config ./vitest.config.ts tests/integration",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e .env -- prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "dotenv -e .env -- prisma db push",
    "db:studio": "dotenv -e .env -- prisma studio",
    "db:seed": "dotenv -e .env -- tsx prisma/seed.ts",
    "db:reset": "dotenv -e .env -- prisma migrate reset --force",
    "format": "prettier --write src/**/*.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.1",
    "@prisma/client": "^6.6.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.3.2",
    "pino": "^9.8.0",
    "pino-pretty": "^11.3.0",
    "prisma": "^6.6.0",
    "uuidv7": "^1.2.1",
    "viem": "^2.23.14",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.15.0",
    "@types/p-queue": "^3.1.0",
    "@types/supertest": "^6.0.3",
    "dotenv-cli": "^8.0.0",
    "prettier": "^3.8.1",
    "supertest": "^7.1.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
